# Trimming with fastp (Q30, length 100)
fastp -i SRR14100018_1.fastq -I SRR14100018_2.fastq \
      -o SRR14100018_trimmed_1.fq.gz -O SRR14100018_trimmed_2.fq.gz \
      -q 30 -l 100 --cut_front --cut_tail --cut_window_size 4 -M 30

# Quality Check
fastqc -o ../fastqc_results/ -t 4 ../fastp_results/*fq.gz
